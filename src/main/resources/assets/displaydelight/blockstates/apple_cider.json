
{
 "multipart": [
  {
   "apply": {
    "model": "displaydelight:block/wood_support"
   },
   "when": {
    "support": "true"
   }
  },{
   "apply": {
    "model": "displaydelight:block/apple_cider"
   },
   "when": {
    "AND":[{"facing":"north"}]
   }
  },{
   "apply": {
    "model": "displaydelight:block/apple_cider",
    "y": 180
   },
   "when": {
    "AND":[{"facing":"south"}]
   }
  },{
   "apply": {
    "model": "displaydelight:block/apple_cider",
    "y": 270
   },
   "when": {
    "AND":[{"facing":"west"}]
   }
  },{
   "apply": {
    "model": "displaydelight:block/apple_cider","y": 90
   },
   "when": {
    "AND":[{"facing":"east"}]
   }
  }
 ]
}